# ── LLM provider ────────────────────────────────────────────────────────────
# Required: your OpenAI API key
OPENAI_API_KEY=sk-...

# Optional: override the default model (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# ── LangSmith observability ──────────────────────────────────────────────────
# Required for tracing: your LangSmith API key
LANGCHAIN_API_KEY=ls__...

# Set to "true" to enable tracing (default: false)
LANGCHAIN_TRACING_V2=true

# Project name shown in the LangSmith UI (default: diseno-multiagente)
LANGCHAIN_PROJECT=diseno-multiagente

# LangSmith API endpoint (default below — change only if using a private instance)
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
